{
  "name": "milk-dreams",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "pnpm --filter milk-dreams-server dev",
    "dev:all": "pnpm run --parallel \"/^dev(:server)?$/\"",
    "build": "tsc --noEmit && vite build",
    "build:server": "pnpm --filter milk-dreams-server build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "pnpm typecheck && pnpm --filter milk-dreams-server typecheck"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd",
  "dependencies": {
    "@colyseus/sdk": "^0.17.40",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
