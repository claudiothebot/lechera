# Phase 5 — Supabase-backed all-time leaderboard + durable round counter.
# Copy this file to `.env` and fill in the values from the Supabase
# dashboard (Project Settings → API). When EITHER variable is unset,
# the server runs without persistence (in-memory ranking only) and
# `/leaderboard` returns an empty list. See lechera/MULTIPLAYER.md for
# the schema + DDL that must be applied to the project beforehand,
# and remember to add `milk_dreams` to "Exposed schemas" in the API
# settings (otherwise PostgREST can't see the RPC functions).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# WRITES are additionally gated on NODE_ENV=production. Even with
# SUPABASE_URL / SUPABASE_ANON_KEY set, `pnpm dev:server` runs in dev
# mode and will NOT write to Supabase (no round-counter bump, no
# ranking upsert). Reads still work — dev sees the same leaderboard
# and durable round counter as production, it just can't modify them.
# This lets you point local dev at the same project as production
# without polluting the real tables. Set `NODE_ENV=production`
# explicitly when you want to exercise the write path locally (the
# leaderboard smoke test does this for you on its persistence-ON path).
