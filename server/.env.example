# Phase 5 — Supabase-backed all-time leaderboard.
# Copy this file to `.env` and fill in the values from the Supabase
# dashboard (Project Settings → API). When EITHER variable is unset,
# the server runs without persistence (in-memory ranking only) and
# `/leaderboard` returns an empty list. See lechera/MULTIPLAYER.md for
# the schema + DDL that must be applied to the project beforehand,
# and remember to add `milk_dreams` to "Exposed schemas" in the API
# settings (otherwise PostgREST can't see the RPC functions).
SUPABASE_URL=
SUPABASE_ANON_KEY=
